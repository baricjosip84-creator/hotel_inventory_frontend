# Production deployments must provide the real backend URL through the
# deployment provider environment, for example Vercel project settings.
# Do not commit tenant/customer-specific or environment-specific backend URLs.
# Vite shell/deployment variables override this safe fallback at build time.
VITE_API_BASE_URL=/api

# Optional frontend error monitoring. Set real values in Vercel project settings.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
