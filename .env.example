# Local development (works with Vite proxy)
VITE_API_BASE_URL=/api

# Production example: set this in your deployment provider environment
# VITE_API_BASE_URL=https://<backend-host>/api

# Public frontend configuration governance placeholders.
# VITE_* values are bundled into the browser and must never contain secrets.
PUBLIC_CONFIG_CHANGE_APPROVER_ROLE=platform_admin
PUBLIC_CONFIG_CHANGE_APPROVAL_REQUIRED=true


# Public feature flag / rollout placeholders.
# VITE_* values are bundled into the browser and must never contain secrets or tokens.
VITE_FEATURE_FLAGS_ENABLED=false
VITE_FEATURE_FLAG_PROVIDER=deployment-config
VITE_FEATURE_FLAG_DEFAULT_ROLLOUT_PERCENT=0

# Deployed-environment smoke-test settings. These are consumed by Playwright and
# GitHub Actions only; they are not bundled because they do not use the VITE_ prefix.
DEPLOYMENT_FRONTEND_URL=https://app.example.com
DEPLOYMENT_BACKEND_URL=https://api.example.com
DEPLOYMENT_REQUIRE_DECISION_INTELLIGENCE=true
DEPLOYMENT_REQUIRE_PLATFORM_AUTH=false
DEPLOYMENT_REQUIRE_SENTRY_SOURCE_MAPS=false
# E2E_EMAIL, E2E_PASSWORD, E2E_PLATFORM_EMAIL, and E2E_PLATFORM_PASSWORD are secrets.

# OPTIONAL RUNTIME ERROR MONITORING
# VITE_SENTRY_DSN is public by design and identifies the frontend Sentry project.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
# Build-only secrets/identifiers for source-map upload; configure in Vercel, never commit values.
# Configure the protected upload token only in Vercel Production; never prefix it with VITE_.
SENTRY_ORG=
SENTRY_PROJECT=
# Set true in Vercel Production after the three values above are configured.
SENTRY_SOURCE_MAPS_REQUIRED=false
# Optional release override; VERCEL_GIT_COMMIT_SHA is used automatically.
# SENTRY_RELEASE=
