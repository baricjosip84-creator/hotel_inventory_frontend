  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "pretest:e2e": "npm run check:unified-ai-contract-suite",
    "test:e2e:ui": "playwright test --ui",
    "check:commercial-shell": "node scripts/check-commercial-shell-regression.mjs",
    "check:phase15-closure": "node scripts/check-phase15-closure.mjs",
    "check:frontend-performance-budget": "node scripts/check-frontend-performance-budget.mjs",
    "check:phase18-commercial-readiness-surfaces": "node scripts/check-phase18-commercial-readiness-surfaces.mjs",
    "check:vercel-install-hardening": "node scripts/check-vercel-install-hardening.mjs",
    "check:platform-security-route-permission": "node scripts/check-platform-security-route-permission.mjs",
    "check:platform-api-mutation-safety": "node scripts/check-platform-api-mutation-safety.mjs",
    "check:production-env-governance": "node scripts/check-production-env-governance.mjs",
    "check:report-csv-export-ui": "node scripts/check-report-csv-export-ui.mjs",
    "check:automation-resume-ui-governance": "node scripts/check-automation-resume-ui-governance.mjs",
    "check:tenant-session-route-auth-governance": "node scripts/check-tenant-session-route-auth-governance.mjs",
    "check:report-export-row-count-ui": "node scripts/check-report-export-row-count-ui.mjs",
    "check:report-export-feature-closure": "node scripts/check-report-export-feature-closure.mjs",
    "check:unified-ai-panel-anchor-contract": "node scripts/check-unified-ai-panel-anchor-contract.mjs",
    "check:unified-ai-response-type-contract": "node scripts/check-unified-ai-response-type-contract.mjs",
    "check:unified-ai-cross-repo-contract": "node scripts/check-unified-ai-cross-repo-contract.mjs",
    "check:unified-ai-contract-suite": "node scripts/check-unified-ai-contract-suite.mjs",
    "check:unified-ai-route-fetch-contract": "node scripts/check-unified-ai-route-fetch-contract.mjs",
    "prelint": "npm run check:unified-ai-contract-suite",
    "pretest:e2e:ui": "npm run check:unified-ai-contract-suite",
    "predev": "npm run check:unified-ai-contract-suite",
    "prepreview": "npm run check:unified-ai-contract-suite",
    "prebuild": "npm run check:unified-ai-contract-suite && npm run typecheck:ci",
    "check:button-action-ux-audit": "node scripts/check-button-action-ux-audit.mjs",
    "check:inventory-usage-quick-consume-draft-preservation": "node scripts/check-inventory-usage-quick-consume-draft-preservation.mjs",
    "check:inventory-usage-reversal-feedback": "node scripts/check-inventory-usage-reversal-feedback.mjs",
    "check:role-permission-management": "node scripts/check-role-permission-management.mjs",
    "check:tenant-custom-role-management": "node scripts/check-tenant-custom-role-management.mjs",
    "check:shipment-mailtrap-sandbox-ui": "node scripts/check-shipment-mailtrap-sandbox-ui.mjs",
    "typecheck": "tsc -b",
    "security:scan": "node scripts/check-committed-secrets.mjs",
    "repo:hygiene": "node scripts/check-repository-hygiene.mjs",
    "security:check": "npm run repo:hygiene && npm run security:scan",
    "lint:pilot-critical": "eslint src/app/router.tsx src/app/navigationRegistry.ts src/lib/api.ts src/lib/auth.ts src/lib/platformApi.ts src/lib/platformAuth.ts src/components/ProtectedRoute.tsx src/components/PlatformProtectedRoute.tsx src/pages/ReplenishmentPlanningPage.tsx src/pages/ProcurementRecommendationsPage.tsx src/pages/StockTransfersPage.tsx src/pages/PurchaseOrdersPage.tsx src/pages/LoginPage.tsx src/pages/PlatformLoginPage.tsx",
    "package:stage": "node scripts/prepare-source-distribution.mjs",
    "check:ci": "npm run security:check && npm run check:dependency-update-governance && npm run check:commercial-shell && npm run check:phase15-closure && npm run check:phase18-commercial-readiness-surfaces && npm run check:vercel-install-hardening && npm run check:platform-security-route-permission && npm run check:platform-api-mutation-safety && npm run check:production-env-governance && npm run check:automation-resume-ui-governance && npm run check:tenant-session-route-auth-governance && npm run check:auth-browser-security-hardening && npm run check:shipment-mailtrap-sandbox-ui && npm run check:decision-intelligence-layout && npm run check:runtime-error-monitoring && npm run check:sentry-source-maps && npm run check:deployment-readiness-gate && npm run typecheck:deployment-readiness",
    "check:cross-repo": "npm run check:unified-ai-contract-suite && npm run check:role-permission-management && npm run check:tenant-custom-role-management",
    "repo:clean-generated": "node scripts/clean-generated-artifacts.mjs",
    "typecheck:ci": "tsc -p tsconfig.pilot-critical.json --noEmit",
    "check:dependency-update-governance": "node scripts/check-dependency-update-governance.mjs",
    "check:auth-browser-security-hardening": "node scripts/check-auth-browser-security-hardening.mjs",
    "check:decision-intelligence-layout": "node scripts/check-decision-intelligence-layout.mjs",
    "test:deployment-readiness": "playwright test --config=playwright.deployment.config.ts",
    "check:deployment-readiness-gate": "node scripts/check-deployment-readiness-gate.mjs",
    "typecheck:deployment-readiness": "tsc -p tsconfig.deployment.json --noEmit",
    "wait:production-deployment": "node scripts/wait-for-production-deployment.mjs",
    "check:runtime-error-monitoring": "node scripts/check-runtime-error-monitoring.mjs",
    "check:sentry-source-maps": "node scripts/check-sentry-source-maps.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.67.0",
    "@tanstack/react-query": "^5.96.2",
    "html5-qrcode": "^2.3.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.44.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  },
  "engines": {
    "node": "24.x",
    "npm": ">=10 <12"
  }
}
